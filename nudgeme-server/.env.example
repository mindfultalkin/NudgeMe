# NudgeMe Production Environment Variables
# Copy to .env and fill your values. Do NOT commit .env!

# Server
PORT=4000

# AI
ANTHROPIC_API_KEY=sk-ant-...

# Email (SendGrid)
SENDGRID_API_KEY=SG....

SENDGRID_FROM_EMAIL=nudge@yourdomain.com

# WhatsApp (AiSensy)
AISENSY_API_KEY=your_aisensy_key_here
AISENSY_CAMPAIGN_NAME=your_campaign_name
